<?xml version="1.0"?>
<launch>

<arg name="path" default="$(find ur10e_sim)/urdf/ur10e_workarea.urdf.xacro" />
<param name="robot_description" command="$(find xacro)/xacro '$(arg path)'" />
<node name="joint_state_publisher_gui" pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" />
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />
<node name="rviz" pkg="rviz" type="rviz" args="-d $(find ur10e_sim)/rviz/rviz_config.rviz" required="true" />

</launch>